# =============================================
# PERFORMANCE ESTOICA - Variáveis de Ambiente
# =============================================
# Copie este arquivo para ".env" e preencha com seus valores reais.
# Este arquivo (.env.example) É versionado no Git.
# O arquivo ".env" NÃO deve ser versionado.

# Banco de Dados
DB_HOST=localhost
DB_USER=seu_usuario
DB_PASS=sua_senha
DB_NAME=performance_estoica

# Aplicação
APP_TIMEZONE=America/Sao_Paulo
APP_ENV=development
